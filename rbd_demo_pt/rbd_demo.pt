      // 474539232528 is "cls-producton"
      "vendor_account=474539232528" : {
        "cost_center": "CC-474",
        "cost_approver": "MCarey@example.com",
        "service_owner": "MCarey@example.com",
        "technical_owner": "PDudley@example.com",
