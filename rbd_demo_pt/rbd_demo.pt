    }

    // Get the existing dimensions in the Org which includes RBDs
    existing_rbd_ids = _.pluck(ds_existing_rbds, "id")

    // Generate application-to-attribute mappings dynamically for ~2000 applications
    // This simulates CMDB as single source of truth
    var application_to_attributes = {}
    var app_list = allocation_group_names["rbd_application"]

    _.each(app_list, function(app_name, app_index) {
      // Use app index to deterministically assign attributes (simulates CMDB lookup)
      application_to_attributes[app_name] = {
        "business_capability": allocation_group_names["business_capabilities"][app_index % allocation_group_names["business_capabilities"].length],
        "service_tier": allocation_group_names["service_tiers"][app_index % allocation_group_names["service_tiers"].length],
        "team": _.keys(allocation_group_names["rbd_team"])[app_index % _.keys(allocation_group_names["rbd_team"]).length],
        "operating_company": allocation_group_names["rbd_operating_company"][app_index % allocation_group_names["rbd_operating_company"].length],
        "environment_type": allocation_group_names["environment_types"][app_index % allocation_group_names["environment_types"].length]
      }

      // Derive portfolio from capability
      var capability = application_to_attributes[app_name]["business_capability"]
      var portfolio_map = {
        "Customer Experience": "Digital Front Office",
        "API Management": "Integration Platform",
        "Supply Chain Management": "Operations Platform",
        "Operations Automation": "Operations Platform",
        "Security & Access Control": "Security Platform",
        "Platform Observability": "Operations Platform",
        "Data Management": "Data & Analytics Platform",
        "Compliance & Governance": "Security Platform",
        "Business Intelligence": "Data & Analytics Platform",
        "Platform Performance": "Operations Platform",
        "Integration Services": "Integration Platform",
        "Infrastructure Management": "Operations Platform",
        "Content Management": "Digital Front Office",
        "Communication Services": "Digital Front Office",
        "Financial Operations": "Enterprise Applications",
        "HR & Talent Management": "Enterprise Applications",
        "Analytics & Insights": "Data & Analytics Platform",
        "Application Security": "Security Platform",
        "Network Services": "Operations Platform",
        "Storage Management": "Operations Platform"
      }
      application_to_attributes[app_name]["service_portfolio"] = portfolio_map[capability] || "Operations Platform"

      // Get team attributes
      var team = application_to_attributes[app_name]["team"]
      var team_data = allocation_group_names["rbd_team"][team] || {}
      application_to_attributes[app_name]["department"] = team_data["department"] || "Engineering"
      application_to_attributes[app_name]["cost_center"] = team_data["cost_center"] || "CC-000"
      application_to_attributes[app_name]["cost_approver"] = team_data["cost_approver"] || ""
      application_to_attributes[app_name]["service_owner"] = team_data["service_owner"] || ""
      application_to_attributes[app_name]["technical_owner"] = team_data["technical_owner"] || ""
    })

    // Process each account to build application-centric dimension hierarchy
    _.each(ds_complete_vendor_account_list, function(acc) {
      // Step 1: Assign Application (foundation layer) - use second character for variety
      var account_first_char = acc.vendor_account.charAt(0).toLowerCase()
      var account_second_char = acc.vendor_account.charAt(1).toLowerCase()
      var account_last_char = acc.vendor_account.charAt(acc.vendor_account.length - 1).toLowerCase()

      var second_char_index = account_starts_with.indexOf(account_second_char)
      if (second_char_index === -1) { second_char_index = 0 }
      acc["rbd_application"] = allocation_group_names["rbd_application"][second_char_index % allocation_group_names["rbd_application"].length] || ""

      // Skip defining an application if this is the "youngest" account
      // This is to simulate accounts which are not yet mapped in the CMDB

      // Step 2-9: Derive ALL CMDB attributes from Application (simulates CMDB as single source of truth)
      var app_attributes = application_to_attributes[acc["rbd_application"]] || {}
      acc["rbd_business_capability"] = app_attributes["business_capability"] || ""
      acc["rbd_service_portfolio"] = app_attributes["service_portfolio"] || ""
      acc["rbd_service_tier"] = app_attributes["service_tier"] || "Tier 4 - Development/Test"
      acc["rbd_team"] = app_attributes["team"] || ""
      acc["rbd_department"] = app_attributes["department"] || ""
      acc["rbd_cost_center"] = app_attributes["cost_center"] || ""
      acc["rbd_cost_approver"] = app_attributes["cost_approver"] || ""
      acc["rbd_service_owner"] = app_attributes["service_owner"] || ""
      acc["rbd_technical_owner"] = app_attributes["technical_owner"] || ""
      acc["rbd_operating_company"] = app_attributes["operating_company"] || ""
      acc["rbd_environment_type"] = app_attributes["environment_type"] || "Development"

      // Step 10: Override Environment Type based on account name patterns
      // Account name patterns can override CMDB defaults for environment type
      if (acc.vendor_account_name.toLowerCase().indexOf("prod") > -1) {
        acc["rbd_environment_type"] = "Production"
        // Production apps typically owned by Engineering
        acc["rbd_department"] = "Engineering"
        // Tier up critical production services
        if (acc["rbd_service_tier"] === "Tier 3 - Business Operational") {
          acc["rbd_service_tier"] = "Tier 2 - Business Critical"
        }
      } else if (acc.vendor_account_name.toLowerCase().indexOf("stag") > -1) {
        acc["rbd_environment_type"] = "Staging"
        acc["rbd_department"] = "Engineering"
      } else if (acc.vendor_account_name.toLowerCase().indexOf("dev") > -1) {
        acc["rbd_environment_type"] = "Development"
      } else if (acc.vendor_account_name.toLowerCase().indexOf("sandbox") > -1 || acc.vendor_account_name.toLowerCase().indexOf("test") > -1) {
        acc["rbd_environment_type"] = "Sandbox"
      }

      // Override mappings if the override exists for a vendor_account
      if (allocation_group_names["vendor_account="+acc.vendor_account]) {
        // Loop through the keys in the override and override the RBD value
        _.each(allocation_group_names["vendor_account="+acc.vendor_account], function(value, key) {
          acc["rbd_"+key] = value
        })
      }
    })


    //New rules list
    var new_rbds = []

    // For each target RBD, create the rules
    _.each(ds_target_rbd_ids, function(target_rbd){
      // rbd_team - CMDB dimension mapped from application
      if (target_rbd.id == "rbd_team") {
        var rules = []
        // Create unique application-to-team mappings from CMDB
        var unique_mappings = {}
        // First, add all applications from CMDB (application_to_attributes)
        _.each(_.keys(application_to_attributes), function(app_name) {
          unique_mappings[app_name] = application_to_attributes[app_name]["team"]
        })
        // Then override with actual values from vendor accounts (if different)
        _.each(ds_complete_vendor_account_list, function (acc){
          if (acc.rbd_application && acc.rbd_team) {
            unique_mappings[acc.rbd_application] = acc.rbd_team
          }
        })
        // Generate rules based on rbd_application dimension
        _.each(_.keys(unique_mappings), function(app_name) {
          rules.push({
            "condition": {
              "type": "dimension_equals",
              "dimension": "rbd_application",
              "value": app_name
            },
            "value": {
              "text": unique_mappings[app_name]
            }
          })
        })

        rbd_json = {
          "verb": _.contains(existing_rbd_ids, target_rbd.id) ? "PATCH" : "POST",
          "id": target_rbd.id,
          "name": target_rbd.name,
          "dated_rules": [
            {
              "effective_at": ds_effective_date.effective_date,
              "rules": rules
            }
          ]
        }
        new_rbds.push(rbd_json)
      }
      // rbd_cost_center - CMDB dimension mapped from application
      if (target_rbd.id == "rbd_cost_center") {
        var rules = []
        var unique_mappings = {}
        // First, add all applications from CMDB
        _.each(_.keys(application_to_attributes), function(app_name) {
          unique_mappings[app_name] = application_to_attributes[app_name]["cost_center"]
        })
        // Then override with actual values from vendor accounts
        _.each(ds_complete_vendor_account_list, function (acc){
          if (acc.rbd_application && acc.rbd_cost_center) {
            unique_mappings[acc.rbd_application] = acc.rbd_cost_center
          }
        })
        _.each(_.keys(unique_mappings), function(app_name) {
          rules.push({
            "condition": {
              "type": "dimension_equals",
              "dimension": "rbd_application",
              "value": app_name
            },
            "value": {
              "text": unique_mappings[app_name]
            }
          })
        })

        rbd_json = {
          "verb": _.contains(existing_rbd_ids, target_rbd.id) ? "PATCH" : "POST",
          "id": target_rbd.id,
          "name": target_rbd.name,
          "dated_rules": [
            {
              "effective_at": ds_effective_date.effective_date,
              "rules": rules
            }
          ]
        }
        new_rbds.push(rbd_json)
      }
      // rbd_cost_approver - CMDB dimension mapped from application
      if (target_rbd.id == "rbd_cost_approver") {
        var rules = []
        var unique_mappings = {}
        // First, add all applications from CMDB
        _.each(_.keys(application_to_attributes), function(app_name) {
          unique_mappings[app_name] = application_to_attributes[app_name]["cost_approver"]
        })
        // Then override with actual values from vendor accounts
        _.each(ds_complete_vendor_account_list, function (acc){
          if (acc.rbd_application && acc.rbd_cost_approver) {
            unique_mappings[acc.rbd_application] = acc.rbd_cost_approver
          }
        })
        _.each(_.keys(unique_mappings), function(app_name) {
          rules.push({
            "condition": {
              "type": "dimension_equals",
              "dimension": "rbd_application",
              "value": app_name
            },
            "value": {
              "text": unique_mappings[app_name]
            }
          })
        })

        rbd_json = {
          "verb": _.contains(existing_rbd_ids, target_rbd.id) ? "PATCH" : "POST",
          "id": target_rbd.id,
          "name": target_rbd.name,
          "dated_rules": [
            {
              "effective_at": ds_effective_date.effective_date,
              "rules": rules
            }
          ]
        }
        new_rbds.push(rbd_json)
      }
      // rbd_application
      if (target_rbd.id == "rbd_application") {
        //Add Rules
        var rules = []

        // Few Static Rules at the top
        // These are intended to be an example of rules that may be manually managed by the Centralized FinOps Personas (in addition to rules generated from CMDB/tags)
        // At top, so that they take precedence over application-based rules which is correct because they have been manually/varified and added by FinOps persona
        // Databricks Commitments
        rules.push({
          "condition": { "type": "and", "expressions": [
            { "dimension": "service", "type": "dimension_contains", "substring": "Databricks Unified Analytics Platform" },
            { "dimension": "service", "type": "dimension_contains", "substring": "Annual Commitment" }
          ] },
          "value": {
            "text": "Data Lake"
          }
        })
        // MongoDB Atlas ODS
        rules.push({
          "condition": { "type": "and", "expressions": [
            { "dimension": "service", "type": "dimension_contains", "substring": "MongoDB Atlas on AWS" },
            { "dimension": "service", "type": "dimension_contains", "substring": "Contract with Usage" }
          ] },
          "value": {
            "text": "Operational Data Store"
          }
        })
        // Prisma Cloud (Annual Contract)
        rules.push({
          "condition": { "type": "and", "expressions": [
            { "dimension": "service", "type": "dimension_contains", "substring": "Prisma Cloud" },
            { "dimension": "service", "type": "dimension_contains", "substring": "Annual Contract" }
          ] },
          "value": {
            "text": "Cloud Security Platform"
          }
        })
        rules.push({
          "condition": { "dimension": "service", "type": "dimension_contains", "substring": "Prisma Access/Prisma SaaS (Private)" },
          "value": {
            "text": "Cloud Security Platform"
          }
        })
        rules.push({
          "condition": { "dimension": "service", "type": "dimension_contains", "substring": "Prisma Cloud Extended Expertise (Resident Engineer - Half Time)" },
          "value": {
            "text": "Cloud Security Platform"
          }
        })
        // Sumo Logic Monitoring and Analytics Platform
        rules.push({
          "condition": { "dimension": "service", "type": "dimension_contains", "substring": "Sumo Logic Monitoring and Analytics Platform" },
          "value": {
            "text": "Observability Platform"
          }
        })
        // PageDuty Operations Cloud
        rules.push({
          "condition": { "dimension": "service", "type": "dimension_contains", "substring": "PagerDuty Operations Cloud" },
          "value": {
            "text": "Incident Response"
          }
        })
        // Udemy Business
        rules.push({
          "condition": { "dimension": "service", "type": "dimension_contains", "substring": "Udemy Business" },
          "value": {
            "text": "Training Management"
          }
        })
        // SolarWinds Solution
        rules.push({
          "condition": { "dimension": "service", "type": "dimension_contains", "substring": "SolarWinds Solution" },
          "value": {
            "text": "Network Monitoring"
          }
        })
        // F5 BIG-IP Virtual Edition
        rules.push({
          "condition": { "dimension": "service", "type": "dimension_contains", "substring": "F5 BIG-IP Virtual Edition" },
          "value": {
            "text": "Load Balancer"
          }
        })

        // Everything below simulates rules generated from Cloud Tenant Tags (i.e. Cloud Account and RGs)
        // This is a typicaly "baseline" strategy, but the rules above show how manual rules can be added to improve coverage or accuracy of allocations

        // Add a Start "Delimiter" which is similar to what we use in "RBD From Account Tag" Policy Templates
        rules.push({
          "condition": { "dimension": "vendor_account", "type": "dimension_equals", "value": "Start: Rule-Based Dimensions from CMDB - Demo Org" },
          "value": {
            "text": "Start: Rule-Based Dimensions from CMDB - Demo Org"
          }
        })

        // Add rules for each Cloud Account
        // We can say these values are derived from the `appplication` tag on Cloud Tenant (Cloud Account or Resource Group)
        // These will allocate costs that are NOT owned by rbd_team=Engineering using the second character of the vendor_account
        _.each(ds_complete_vendor_account_list, function (acc){
          // Check if this is the "youngest" account
          if (acc.is_youngest_account) {
            // We intentionally skip adding a rule for the youngest account to simulate "imperfect" environment
            return
          }

          rules.push({
            "condition": {
              "type": "dimension_equals",
              "dimension": "vendor_account",
              "value": acc.vendor_account
            },
            "value": {
              "text": acc.rbd_application
            }
          })
        })

        // Add a End "Delimiter" which is similar to what we use in "RBD From Account Tag" Policy Templates
        rules.push({
          "condition": { "dimension": "vendor_account", "type": "dimension_equals", "value": "End: Rule-Based Dimensions from CMDB - Demo Org" },
          "value": {
            "text": "End: Rule-Based Dimensions from CMDB - Demo Org"
          }
        })

        // Add a Start "Delimiter" rule
        // rules.push({
        //   "condition": { "dimension": "vendor_account", "type": "dimension_contains", "substring": "Start: Rule-Based Dimensions from CMDB - Demo Org", "caseInsensitive": true },
        //   "value": {
        //     "text": "Start: Fallback rules for Demo Org"
        //   }
        // })
        // // Fallback rules for demo env, in case we have recommendations that do not have any costs (i.e. Demo PT)
        // for (var i = 0; i < account_starts_with.length; i++) {
        //   var char = account_starts_with[i]
        //   rules.push({
        //     "condition": {
        //       "type": "dimension_contains",
        //       "dimension": "vendor_account",
        //       "substring": char,
        //       "caseInsensitive": true
        //     },
        //     "value": {
        //       "text": allocation_group_names["rbd_application"][i % allocation_group_names["rbd_application"].length]
        //     }
        //   })
        // }
        // rules.push({
        //   "condition": { "dimension": "vendor_account", "type": "dimension_contains", "substring": "End: Rule-Based Dimensions from CMDB - Demo Org", "caseInsensitive": true },
        //   "value": {
        //     "text": "End: Fallback rules for Demo Org"
        //   }
        // })

        // Construct final RBD Payload
        rbd_json = {
          "verb": _.contains(existing_rbd_ids, target_rbd.id) ? "PATCH" : "POST",
          "id": target_rbd.id,
          "name": target_rbd.name,
          "dated_rules": [
            {
              "effective_at": ds_effective_date.effective_date,
              "rules": rules
            }
          ]
        }
        //Push to new RBDs json
        new_rbds.push(rbd_json)
      }
      // rbd_environment_type - CMDB dimension mapped from application
      if (target_rbd.id == "rbd_environment_type") {
        var rules = []
        var unique_mappings = {}
        // First, add all applications from CMDB
        _.each(_.keys(application_to_attributes), function(app_name) {
          unique_mappings[app_name] = application_to_attributes[app_name]["environment_type"]
        })
        // Then override with actual values from vendor accounts
        _.each(ds_complete_vendor_account_list, function (acc){
          if (acc.rbd_application && acc.rbd_environment_type) {
