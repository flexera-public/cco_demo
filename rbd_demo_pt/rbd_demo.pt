      "id": "rbd_service_tier",
      "name": "CMDB-Service Tier"
    },
    // Business Layer
    {
      "id": "rbd_business_capability",
      "name": "CMDB-Business Capability" // Name must be under 30 characters (from CMDB) resulted in 31 chars
    },
    {
      "id": "rbd_service_portfolio",
      "name": "CMDB-Service Portfolio"
    },
    // Organizational Layer
    {
      "id": "rbd_team",
      "name": "CMDB-Team"
    },
    {
      "id": "rbd_service_owner",
      "name": "CMDB-Service Owner"
    },
    {
      "id": "rbd_technical_owner",
      "name": "CMDB-Technical Owner"
    },
    {
      "id": "rbd_department",
      "name": "CMDB-Department"
    },
    // Financial Layer
    {
      "id": "rbd_cost_center",
      "name": "CMDB-Cost Center"
    },
    {
      "id": "rbd_cost_approver",
      "name": "CMDB-Cost Approver"
    },
    // Enterprise Layer
    {
      "id": "rbd_operating_company",
      "name": "CMDB-Operating Company"
    }
  ]
