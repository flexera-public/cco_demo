name "Rule-Based Dimensions from CMDB - Demo Org"
rs_pt_ver 20180301
type "policy"
short_description "Creates and/or updates individual Rule-Based Dimensions based on AWS Account tags. See the [README](https://github.com/flexera-public/policy_templates/tree/master/automation/aws/aws_rbd_from_tag) and [docs.flexera.com/flexera/EN/Automation](https://docs.flexera.com/flexera/EN/Automation/AutomationGS.htm) to learn more."
long_description ""
severity "low"
category "Cost"
default_frequency "daily"
info(
  version: "0.1.0",
  provider: "Flexera",
  service: "Optima",
  policy_set: "Automation",
  publish: "false"
)

###############################################################################
# Parameters
###############################################################################

parameter "param_month_effective_date" do
  type "string"
  label "Effective Date"
  description "Choose whether you want the Effective Date for the rules to be the Current Month or a Specific Month."
  default "Specific Month"
  allowed_values "Current Month", "Specific Month"
end

parameter "param_specific_effective_date" do
  type "string"
  label "Specific Effective Date"
  description "If you chose Specific Effective Date, please enter the Year/month you want rules to start applying in YYYY-MM format"
  default "1970-01"
  allowed_pattern /^(19|20)\d\d-(0[1-9]|1[0-2])$/
end

parameter "param_sn_endpoint" do
  type "string"
  category "Policy Settings"
  label "ServiceNow API Endpoint"
  description "The ServiceNow API Endpoint to use. Example: account12345.service-now.com"
  default "buyersellercorp.service-now.com"
end


###############################################################################
# Authentication
###############################################################################

credentials "auth_flexera" do
  schemes "oauth2"
  label "flexera"
  description "Select FlexeraOne OAuth2 credential."
  tags "provider=flexera"
end

###############################################################################
# Datasources & Scripts
###############################################################################

pagination "pagination_servicenow" do
  get_page_marker do
    body_path jq(response, 'if .result | length < 10000 then null else if $marker != "" then $marker | tonumber + 10000 else 10000 end end')
  end
  set_page_marker do
    query "sysparm_offset"
  end
end

# Get the data from CMDB Tables
datasource "ds_snow_pm_portfolio" do
  request do
    pagination $pagination_servicenow
    host $param_sn_endpoint
    path "/api/now/table/pm_portfolio"
    query "sysparm_fields", "sys_id,name,portfolio_manager,u_portfolio_rollup"
    header "User-Agent", "RS Policies"
    header "Content-Type", "application/json"
  end
  result do
    encoding "json"
    collect jmes_path(response, "result[*]") do
      field "name", jmes_path(col_item, "name")
      field "sys_id", jmes_path(col_item, "sys_id")
      field "portfolio_manager", jmes_path(col_item, "portfolio_manager")
      field "u_portfolio_rollup", jmes_path(col_item, "u_portfolio_rollup")
    end
  end
end

datasource "ds_snow_sys_user" do
  request do
    pagination $pagination_servicenow
    host $param_sn_endpoint
    path '/api/now/table/sys_user'
    query "sysparm_fields", "sys_id,name"
    query "sysparm_query", "active=true" # We need to limit to active users to reduce the number of results.  This is OK because we only need this data to map "Cost Approvers" which should be comprised of only active users.
    header "User-Agent", "RS Policies"
    header "Content-Type", "application/json"
  end
  result do
    encoding "json"
    collect jmes_path(response, "result[*]") do
      field "name", jmes_path(col_item, "name")
      field "sys_id", jmes_path(col_item, "sys_id")
    end
  end
end

datasource "ds_snow_pm_program" do
  request do
    pagination $pagination_servicenow
    host $param_sn_endpoint
    path "/api/now/table/pm_program"
    query "sysparm_fields", "sys_id,portfolio,short_description"
    header "User-Agent", "RS Policies"
    header "Content-Type", "application/json"
  end
  result do
    encoding "json"
    collect jmes_path(response, "result[*]") do
      field "portfolio", jmes_path(col_item, "portfolio.value")
      field "short_description", jmes_path(col_item, "short_description")
      field "sys_id", jmes_path(col_item, "sys_id")
    end
  end
end

datasource "ds_snow_cmdb_ci_business_app" do
  request do
    pagination $pagination_servicenow
    host $param_sn_endpoint
    path "/api/now/table/cmdb_ci_business_app"
    query "sysparm_fields", "sys_id,portfolio,name,u_application_code,u_disaster_recovery_code,u_program,install_status,operational_status"
    header "User-Agent", "RS Policies"
    header "Content-Type", "application/json"
  end
  result do
    encoding "json"
    collect jmes_path(response, "result[*]") do
      field "name", jmes_path(col_item, "name")
      field "portfolio", jmes_path(col_item, "portfolio.value")
      field "sys_id", jmes_path(col_item, "sys_id")
      field "u_application_code", jmes_path(col_item, "u_application_code")
      field "u_disaster_recovery_code", jmes_path(col_item, "u_disaster_recovery_code")
      field "u_program", jmes_path(col_item, "u_program.value")
      field "install_status", jmes_path(col_item, "install_status")
      field "operational_status", jmes_path(col_item, "operational_status")
    end
  end
end

# Full list of Rule-Based Dimensions that will be created/managed based on CMDB data
datasource "ds_target_rbd_ids" do
  run_script $js_create_list_of_target_rbds
end

